# API providers
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Default model
DEFAULT_MODEL=gpt-5.4-mini
# DEFAULT_MODEL=gpt-4o

# Logging
LOG_LEVEL=INFO

# App environment
APP_ENV=development

# PostgreSQL (Python service)
DATABASE_URL=postgresql://user:password@localhost:5433/agent_db
REDIS_URL=redis://localhost:6380/0

# Python gRPC server
GRPC_PORT=50051

# AI hook logging (instructor provided)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=your_ai_log_api_key_here
AI_LOG_DIR=.ai-log

# Python backend
ADMIN_TOKEN=your_admin_token_here
INTERNAL_CALLBACK_TOKEN=your_internal_callback_token_here
JAVA_CALLBACK_URL=http://localhost:8080

# Java backend (Spring Boot)
DB_URL=jdbc:postgresql://localhost:5433/agent_db
DB_NAME=agent_db
DB_USERNAME=user
DB_PASSWORD=password
POSTGRES_HOST_PORT=5433
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_HOST_PORT=6380
REDIS_USERNAME=default
REDIS_PASSWORD=
JWT_SECRET_KEY=replace_with_base64_secret_key_min_256_bits
JWT_EXPIRATION=86400000
PYTHON_GRPC_URL=static://localhost:50051
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_JAVA_API_URL=http://localhost:8080
